# AI Assistant configuration. Copy this file to `.env.local` and edit. `.env.local`
# is in .gitignore so the real file is never committed.
#
# Two transport modes — set ONE of the two:
#
# 1. PROXY MODE (recommended for any deployment)
#    Your Cloudflare Worker URL. The browser never sees your Anthropic key.
#    Safe for public GitHub Pages — anyone can use the demo without leaking creds.
VITE_PROXY_URL=https://aso-demo-proxy.anant-jadon25.workers.dev

# 2. DIRECT MODE (laptop dev only — DO NOT use for public deploys)
#    Browser calls Anthropic directly with this key. Anthropic may revoke it
#    if it appears in browser traffic. Useful only when developing locally
#    and you can't reach the proxy.
# VITE_ANTHROPIC_KEY=sk-ant-api03-YOUR-KEY-HERE

# If both are set, PROXY mode wins.
# If neither is set, chat uses scripted fallback responses.
